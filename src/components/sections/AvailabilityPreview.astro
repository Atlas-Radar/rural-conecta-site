---
import { availabilityRegions, site } from "../../data/site";

const routeSteps = [
  "Região",
  "Localização",
  "Pré-análise",
  "WhatsApp",
] as const;
---

<section
  id="disponibilidade"
  class="availability-modal-host"
  data-availability-root
  data-whatsapp-digits={site.whatsapp.digits}
>
  <dialog
    class="availability-modal"
    aria-modal="true"
    aria-labelledby="availability-modal-title"
    aria-describedby="availability-modal-description"
    data-availability-modal
    tabindex="-1"
  >
    <div class="availability-modal__surface">
      <header class="availability-modal__header">
        <div class="availability-modal__title-group">
          <span class="availability-modal__target" aria-hidden="true">
            <svg viewBox="0 0 48 48" focusable="false">
              <path d="M24 5v8"></path>
              <path d="M24 35v8"></path>
              <path d="M5 24h8"></path>
              <path d="M35 24h8"></path>
              <circle cx="24" cy="24" r="15"></circle>
              <circle cx="24" cy="24" r="8"></circle>
              <circle cx="24" cy="24" r="2.8"></circle>
            </svg>
          </span>
          <div>
            <h2 id="availability-modal-title">
              Pré-análise de disponibilidade
            </h2>
            <p id="availability-modal-description">
              Verificação rápida de viabilidade para o ponto informado.
            </p>
          </div>
        </div>

        <button
          class="availability-modal__close"
          type="button"
          aria-label="Fechar pré-análise"
          data-availability-modal-close
        >
          <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24">
            <path d="m6 6 12 12"></path>
            <path d="M18 6 6 18"></path>
          </svg>
        </button>
      </header>

      <ol class="availability-modal__stepper" aria-label="Etapas da consulta">
        {
          routeSteps.map((step, index) => (
            <li class={index === 0 ? "is-active" : undefined}>
              <span>{index + 1}</span>
              <strong>{step}</strong>
            </li>
          ))
        }
      </ol>

      <div class="availability-modal__body">
        <div class="availability-modal__controls">
          <div class="availability-region-card">
            <div class="availability-region-card__copy">
              <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24">
                <path d="M12 21s6-5.4 6-10a6 6 0 1 0-12 0c0 4.6 6 10 6 10Z"
                ></path>
                <circle cx="12" cy="11" r="2"></circle>
              </svg>
              <div>
                <h3>1. Escolha a região ou localidade</h3>
                <p>Informe onde deseja verificar a disponibilidade.</p>
              </div>
            </div>

            <label class="field-label" for="availability-region">
              Possível região/localidade
            </label>
            <select
              id="availability-region"
              class="field-control"
              data-availability-region
            >
              {
                availabilityRegions.map((region) => (
                  <option value={region} selected={region === "Novo Barreiro"}>
                    {region}
                  </option>
                ))
              }
            </select>
            <p
              class="availability-modal__microcopy"
              data-availability-region-status
            >
              Regiões carregam quando a pré-análise é aberta.
            </p>
          </div>

          <button
            class="availability-realtime"
            type="button"
            data-availability-realtime-location
          >
            <span class="availability-realtime__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M12 3v3"></path>
                <path d="M12 18v3"></path>
                <path d="M3 12h3"></path>
                <path d="M18 12h3"></path>
                <circle cx="12" cy="12" r="5.8"></circle>
                <circle cx="12" cy="12" r="1.7"></circle>
              </svg>
            </span>
            <span data-availability-realtime-label>
              Pegar localização em tempo real
            </span>
            <small>GPS</small>
          </button>

          <div class="availability-modal__divider">
            <span></span>
            <strong>Outras formas de informar</strong>
            <span></span>
          </div>

          <div
            class="availability-actions"
            aria-label="Outras formas de informar"
          >
            <button
              class="availability-action"
              type="button"
              data-availability-action="search"
            >
              <span class="availability-action__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <circle cx="10.5" cy="10.5" r="5.4"></circle>
                  <path d="m15 15 4.2 4.2"></path>
                </svg>
              </span>
              <span>
                <strong>Buscar fazenda ou local</strong>
                <small>Use uma referência e confirme por coordenadas.</small>
              </span>
              <svg
                class="availability-action__arrow"
                aria-hidden="true"
                viewBox="0 0 24 24"
              >
                <path d="m9 6 6 6-6 6"></path>
              </svg>
            </button>

            <button
              class="availability-action"
              type="button"
              data-availability-action="map"
            >
              <span class="availability-action__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="m4 6 5-2 6 2 5-2v14l-5 2-6-2-5 2Z"></path>
                  <path d="M9 4v14"></path>
                  <path d="M15 6v14"></path>
                </svg>
              </span>
              <span>
                <strong>Escolher no mapa</strong>
                <small>Mapa real entra na próxima onda, sob demanda.</small>
              </span>
              <svg
                class="availability-action__arrow"
                aria-hidden="true"
                viewBox="0 0 24 24"
              >
                <path d="m9 6 6 6-6 6"></path>
              </svg>
            </button>

            <button
              class="availability-action"
              type="button"
              data-availability-action="coordinates"
            >
              <span class="availability-action__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M12 4v3"></path>
                  <path d="M12 17v3"></path>
                  <path d="M4 12h3"></path>
                  <path d="M17 12h3"></path>
                  <circle cx="12" cy="12" r="4"></circle>
                </svg>
              </span>
              <span>
                <strong>Informar coordenadas</strong>
                <small>Digite o ponto diretamente.</small>
              </span>
              <svg
                class="availability-action__arrow"
                aria-hidden="true"
                viewBox="0 0 24 24"
              >
                <path d="m9 6 6 6-6 6"></path>
              </svg>
            </button>
          </div>

          <div class="availability-coordinate-card">
            <div class="availability-coordinate-card__heading">
              <label class="field-label" for="availability-coordinates">
                Coordenadas do ponto
              </label>
              <span>Conversão automática</span>
            </div>
            <input
              id="availability-coordinates"
              class="field-control"
              type="text"
              inputmode="text"
              placeholder="-16.448694, -46.906306 ou 16°26'55&quot;S, 46°54'22&quot;W"
              autocomplete="off"
              data-availability-coordinates
            />
            <p class="field-hint">Aceita DD, DMS ou lat,lng no mesmo campo.</p>
          </div>

          <p class="availability-modal__helper" data-availability-helper>
            Informe o ponto da propriedade. Use localização em tempo real ou
            coordenadas.
          </p>

          <button
            class="availability-submit"
            type="button"
            data-availability-submit
            disabled
          >
            <span>Consultar pré-análise</span>
            <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24">
              <path d="M5 12h13"></path>
              <path d="m13 6 6 6-6 6"></path>
            </svg>
          </button>

          <p class="privacy-note availability-modal__privacy">
            Sem cadastro. Não pedimos nome, telefone, e-mail ou CPF.
          </p>
        </div>

        <aside
          class="availability-modal__map"
          aria-label="Mapa de referência sem Google Maps"
          data-availability-map-placeholder
        >
          <div class="availability-map-art" aria-hidden="true">
            <span class="availability-map-art__badge">Mapa de referência</span>
            <span
              class="availability-map-art__road availability-map-art__road--one"
            ></span>
            <span
              class="availability-map-art__road availability-map-art__road--two"
            ></span>
            <span
              class="availability-map-art__road availability-map-art__road--three"
            ></span>
            <span
              class="availability-map-art__ring availability-map-art__ring--outer"
            ></span>
            <span
              class="availability-map-art__ring availability-map-art__ring--inner"
            ></span>
            <span class="availability-map-art__point"></span>
            <span class="availability-map-art__scale">500 m</span>
            <span
              class="availability-map-art__control availability-map-art__control--plus"
              >+</span
            >
            <span
              class="availability-map-art__control availability-map-art__control--minus"
              >−</span
            >
          </div>

          <div class="availability-map-copy">
            <p class="section-kicker">Ponto informado</p>
            <h3>Sem infraestrutura exposta.</h3>
            <p>
              Mock visual leve. Nenhum Google Maps ou Places é carregado nesta
              onda.
            </p>
          </div>

          <div
            class="availability-result"
            data-availability-result
            aria-live="polite"
            hidden
          >
            <p class="availability-result__eyebrow">Resultado da pré-análise</p>
            <h3 data-availability-result-title>Pré-análise</h3>
            <p data-availability-result-message>
              A resposta aparecerá aqui depois da consulta.
            </p>
            <div class="availability-result__actions">
              <a
                class="availability-result__whatsapp"
                href={`https://wa.me/${site.whatsapp.digits}`}
                target="_blank"
                rel="noopener noreferrer"
                data-availability-whatsapp
              >
                Continuar pelo WhatsApp
              </a>
              <button
                class="availability-result__edit"
                type="button"
                data-availability-edit
              >
                Editar coordenadas
              </button>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </dialog>
</section>

<script>
  import "../../scripts/availability";
</script>

<style>
  .availability-modal-host {
    display: contents;
  }

  .availability-modal {
    width: 100%;
    max-width: none;
    height: 100dvh;
    max-height: none;
    margin: 0;
    border: 0;
    background: transparent;
    color: var(--color-text-primary);
    padding: 0;
    z-index: 100;
  }

  .availability-modal::backdrop {
    background: rgba(0, 0, 0, 0.74);
    backdrop-filter: blur(3px);
  }

  .availability-modal__surface {
    position: relative;
    display: grid;
    height: 100%;
    grid-template-rows: auto auto minmax(0, 1fr);
    overflow: hidden;
    border: 1px solid rgba(161, 242, 124, 0.16);
    background:
      radial-gradient(
        circle at 8% 8%,
        rgba(99, 212, 59, 0.18),
        transparent 16rem
      ),
      linear-gradient(145deg, rgba(6, 21, 20, 0.98), rgba(1, 7, 8, 0.98));
    box-shadow: 0 1.5rem 4rem rgba(0, 0, 0, 0.48);
  }

  .availability-modal__header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.8rem;
    align-items: start;
    padding: max(0.85rem, env(safe-area-inset-top)) 0.85rem 0.65rem;
  }

  .availability-modal__title-group {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.75rem;
    align-items: center;
    min-width: 0;
  }

  .availability-modal__target {
    display: grid;
    width: 2.7rem;
    height: 2.7rem;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 999px;
    background: rgba(99, 212, 59, 0.12);
    color: var(--color-green-300);
  }

  .availability-modal__target svg,
  .availability-modal__close svg,
  .availability-region-card svg,
  .availability-realtime svg,
  .availability-action svg,
  .availability-submit svg {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .availability-modal__target svg {
    width: 2.25rem;
    height: 2.25rem;
    stroke-width: 2.2;
  }

  .availability-modal__header h2 {
    font-size: clamp(1.35rem, 6vw, 2rem);
    line-height: 1.05;
    margin: 0;
  }

  .availability-modal__header p {
    color: var(--color-text-secondary);
    font-size: 0.86rem;
    line-height: 1.35;
    margin: 0.25rem 0 0;
  }

  .availability-modal__close {
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-control);
    background: rgba(245, 247, 243, 0.04);
    color: var(--color-text-primary);
    cursor: pointer;
  }

  .availability-modal__close svg {
    width: 1.15rem;
    height: 1.15rem;
    stroke-width: 2.4;
  }

  .availability-modal__stepper {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.35rem;
    margin: 0;
    padding: 0 0.85rem 0.65rem;
    list-style: none;
  }

  .availability-modal__stepper li {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 0.28rem;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 840;
    line-height: 1.1;
    text-align: center;
  }

  .availability-modal__stepper li:not(:last-child)::after {
    position: absolute;
    top: 0.88rem;
    left: calc(50% + 1.05rem);
    width: calc(100% - 1.65rem);
    height: 1px;
    background: rgba(245, 247, 243, 0.18);
    content: "";
  }

  .availability-modal__stepper span {
    position: relative;
    z-index: 1;
    display: grid;
    width: 1.75rem;
    height: 1.75rem;
    place-items: center;
    border: 1px solid rgba(245, 247, 243, 0.22);
    border-radius: 999px;
    background: rgba(2, 11, 12, 0.8);
    color: var(--color-text-secondary);
    font-size: 0.78rem;
  }

  .availability-modal__stepper .is-active span {
    border-color: var(--color-green-300);
    color: var(--color-green-300);
    box-shadow: 0 0 0 0.25rem rgba(161, 242, 124, 0.1);
  }

  .availability-modal__body {
    display: grid;
    gap: 0.8rem;
    min-height: 0;
    overflow-y: auto;
    padding: 0 0.85rem max(0.85rem, env(safe-area-inset-bottom));
  }

  .availability-modal__controls {
    display: grid;
    gap: 0.7rem;
    min-width: 0;
  }

  .availability-region-card,
  .availability-coordinate-card,
  .availability-modal__map,
  .availability-result {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    background: rgba(2, 11, 12, 0.34);
  }

  .availability-region-card {
    display: grid;
    gap: 0.55rem;
    padding: 0.75rem;
  }

  .availability-region-card__copy {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.55rem;
    align-items: center;
  }

  .availability-region-card__copy svg {
    width: 2.05rem;
    height: 2.05rem;
    color: var(--color-green-300);
    stroke-width: 2.1;
  }

  .availability-region-card h3 {
    font-size: 1rem;
    line-height: 1.15;
    margin: 0;
  }

  .availability-region-card p,
  .availability-modal__microcopy {
    color: var(--color-text-muted);
    font-size: 0.82rem;
    line-height: 1.32;
    margin: 0;
  }

  .availability-region-card .field-control,
  .availability-coordinate-card .field-control {
    min-height: 2.85rem;
    font-size: 1rem;
    padding-block: 0.72rem;
  }

  .availability-realtime {
    display: grid;
    min-height: 5.75rem;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
    border: 1px solid var(--color-primary-hover);
    border-radius: 1rem;
    background: var(--gradient-primary);
    color: var(--color-text-inverse);
    cursor: pointer;
    font-size: 1.06rem;
    font-weight: 950;
    line-height: 1.15;
    padding: 0.85rem;
    text-align: left;
    box-shadow: 0 0 0 0.35rem rgba(99, 212, 59, 0.08);
  }

  .availability-realtime:disabled {
    cursor: progress;
    opacity: 0.78;
  }

  .availability-realtime__icon {
    display: grid;
    width: 2.95rem;
    height: 2.95rem;
    place-items: center;
    border: 2px solid rgba(4, 17, 13, 0.32);
    border-radius: 999px;
  }

  .availability-realtime svg {
    width: 2rem;
    height: 2rem;
    stroke-width: 2.4;
  }

  .availability-realtime small {
    border-radius: var(--radius-chip);
    background: rgba(4, 17, 13, 0.26);
    font-size: 0.72rem;
    font-weight: 950;
    padding: 0.35rem 0.58rem;
  }

  .availability-modal__divider {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.55rem;
    align-items: center;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .availability-modal__divider span {
    height: 1px;
    background: rgba(245, 247, 243, 0.16);
  }

  .availability-actions {
    display: grid;
    gap: 0.45rem;
  }

  .availability-action {
    display: grid;
    width: 100%;
    min-height: 3.6rem;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.65rem;
    align-items: center;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-control);
    background: rgba(245, 247, 243, 0.035);
    color: var(--color-text-primary);
    cursor: pointer;
    padding: 0.6rem;
    text-align: left;
  }

  .availability-action:hover,
  .availability-action:focus-visible {
    border-color: var(--color-border-green);
    background: rgba(99, 212, 59, 0.08);
  }

  .availability-action__icon {
    display: grid;
    width: 2.45rem;
    height: 2.45rem;
    place-items: center;
    border: 1px solid var(--color-border-green);
    border-radius: 0.72rem;
    color: var(--color-green-300);
  }

  .availability-action__icon svg {
    width: 1.28rem;
    height: 1.28rem;
    stroke-width: 2.3;
  }

  .availability-action strong,
  .availability-action small {
    display: block;
  }

  .availability-action strong {
    font-size: 0.92rem;
    line-height: 1.15;
  }

  .availability-action small {
    color: var(--color-text-muted);
    font-size: 0.76rem;
    line-height: 1.25;
    margin-top: 0.1rem;
  }

  .availability-action__arrow {
    width: 1.15rem;
    height: 1.15rem;
    color: var(--color-text-muted);
    stroke-width: 2.3;
  }

  .availability-coordinate-card {
    display: grid;
    gap: 0.55rem;
    padding: 0.75rem;
  }

  .availability-coordinate-card__heading {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    justify-content: space-between;
  }

  .availability-coordinate-card__heading span {
    border: 1px solid var(--color-border-green);
    border-radius: var(--radius-chip);
    background: var(--color-green-soft);
    color: var(--color-green-300);
    font-size: 0.72rem;
    font-weight: 900;
    line-height: 1;
    padding: 0.42rem 0.58rem;
  }

  .field-hint,
  .availability-modal__helper {
    color: var(--color-text-muted);
    font-size: 0.82rem;
    line-height: 1.35;
    margin: 0;
  }

  .availability-modal__helper {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-control);
    background: rgba(245, 247, 243, 0.035);
    padding: 0.65rem 0.75rem;
  }

  .availability-submit {
    display: inline-flex;
    min-height: 3.35rem;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    border: 1px solid var(--color-primary-hover);
    border-radius: 1rem;
    background: var(--gradient-primary);
    color: var(--color-text-inverse);
    cursor: pointer;
    font-weight: 950;
    padding: 0.9rem 1rem;
  }

  .availability-submit:disabled {
    border-color: var(--color-border-subtle);
    background: rgba(245, 247, 243, 0.08);
    color: var(--color-text-muted);
    cursor: not-allowed;
  }

  .availability-submit svg {
    width: 1.2rem;
    height: 1.2rem;
    stroke-width: 2.3;
  }

  .availability-modal__privacy {
    margin: 0;
  }

  .availability-modal__map {
    position: relative;
    display: grid;
    min-height: 14rem;
    overflow: hidden;
    padding: 0;
  }

  .availability-map-art {
    position: relative;
    min-height: 10.5rem;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border-subtle);
    background:
      linear-gradient(90deg, rgba(245, 247, 243, 0.045) 1px, transparent 1px),
      linear-gradient(0deg, rgba(245, 247, 243, 0.045) 1px, transparent 1px),
      radial-gradient(
        circle at 50% 52%,
        rgba(99, 212, 59, 0.22),
        transparent 5rem
      ),
      linear-gradient(145deg, rgba(5, 25, 22, 0.98), rgba(2, 11, 12, 0.94));
    background-size:
      2rem 2rem,
      2rem 2rem,
      auto,
      auto;
  }

  .availability-map-art__badge,
  .availability-map-art__scale,
  .availability-map-art__control {
    position: absolute;
    z-index: 2;
    border: 1px solid var(--color-border-subtle);
    background: rgba(2, 11, 12, 0.72);
    color: var(--color-text-secondary);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .availability-map-art__badge {
    top: 0.75rem;
    left: 0.75rem;
    border-radius: var(--radius-control);
    padding: 0.42rem 0.62rem;
  }

  .availability-map-art__scale {
    right: 1rem;
    bottom: 1rem;
    border-width: 0 0 2px;
    background: transparent;
    padding-inline: 0.75rem;
  }

  .availability-map-art__control {
    right: 0.75rem;
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border-radius: 0.55rem;
    color: var(--color-text-primary);
    font-size: 1.15rem;
  }

  .availability-map-art__control--plus {
    top: 0.75rem;
  }

  .availability-map-art__control--minus {
    top: 2.9rem;
  }

  .availability-map-art__road {
    position: absolute;
    height: 0.18rem;
    border-radius: 999px;
