---
import { availabilityRegions, locationMethods, site } from "../../data/site";

const iconLabels = {
  gps: "GPS",
  search: "Busca",
  map: "Mapa",
  pin: "Coord.",
} as const;

const routeSteps = [
  "Escolha a possível região/localidade",
  "Informe o ponto da propriedade",
  "Consulte a pré-análise",
  "Continue pelo WhatsApp",
] as const;
---

<section
  id="disponibilidade"
  class="section-band section-band--dark availability-preview"
  aria-labelledby="disponibilidade-title"
>
  <div class="container">
    <div class="section-heading section-heading--centered">
      <p class="section-kicker">Pré-análise de disponibilidade</p>
      <h2 id="disponibilidade-title" class="section-title">
        Faça uma pré-análise do ponto da propriedade.
      </h2>
      <p class="section-lede">
        Escolha uma possível região/localidade e informe coordenadas do local. A
        resposta mostra apenas um indício de viabilidade; a confirmação final
        continua com avaliação manual da equipe.
      </p>
    </div>

    <ol class="availability-preview__path" aria-label="Caminho da consulta">
      {
        routeSteps.map((step, index) => (
          <li>
            <span aria-hidden="true">{index + 1}</span>
            {step}
          </li>
        ))
      }
    </ol>

    <div
      class="availability-preview__grid"
      data-availability-root
      data-whatsapp-digits={site.whatsapp.digits}
    >
      <div class="visual-card availability-preview__panel">
        <div class="availability-preview__panel-header">
          <p class="section-kicker">Consulta sem cadastro</p>
          <h3>Comece pela região e pelo ponto</h3>
          <p>
            No celular, use sua localização. Se preferir, informe latitude e
            longitude em decimal.
          </p>
        </div>

        <div
          class="availability-preview__block availability-preview__block--region"
        >
          <label class="field-label" for="availability-region">
            Possível região/localidade
          </label>
          <select
            id="availability-region"
            class="field-control"
            data-availability-region
          >
            {
              availabilityRegions.map((region) => (
                <option value={region} selected={region === "Novo Barreiro"}>
                  {region}
                </option>
              ))
            }
          </select>

          <div
            class="availability-preview__selected"
            aria-live="polite"
            data-availability-region-status
          >
            <span aria-hidden="true"></span>
            <p>Carregando possíveis regiões...</p>
          </div>
        </div>

        <div
          class="availability-preview__block availability-preview__block--methods"
          role="group"
          aria-labelledby="location-methods-title"
        >
          <p id="location-methods-title" class="field-label">
            Como deseja localizar sua propriedade?
          </p>
          <div class="availability-preview__methods">
            {
              locationMethods.map((method, index) => (
                <button
                  class:list={[
                    "method-card",
                    index === 0 && "method-card--active",
                  ]}
                  type="button"
                  aria-pressed={index === 0 ? "true" : "false"}
                  data-availability-method={method.icon}
                >
                  <span class="method-card__icon" aria-hidden="true">
                    {iconLabels[method.icon]}
                  </span>
                  <span>
                    <strong>{method.title}</strong>
                    <small>{method.description}</small>
                  </span>
                </button>
              ))
            }
          </div>
        </div>

        <div
          class="availability-preview__manual"
          aria-label="Alternativas de localização sem mapa"
        >
          <div class="availability-preview__search-box">
            <label class="field-label" for="availability-search">
              Buscar fazenda, estrada ou referência
            </label>
            <input
              id="availability-search"
              class="field-control"
              type="search"
              placeholder="Ex.: Fazenda Santa Rosa, estrada ou comunidade"
              autocomplete="off"
              data-availability-search
            />
            <p class="field-hint">
              A busca por local ainda é apoio visual. Para enviar a pré-análise
              automática, informe latitude e longitude.
            </p>
          </div>

          <div class="availability-preview__coordinate-card">
            <div class="availability-preview__coordinate-copy">
              <p class="section-kicker">Alternativa técnica</p>
              <p>
                Cole as coordenadas do ponto da casa, sede, sítio ou fazenda.
              </p>
            </div>
            <div class="availability-preview__coordinates">
              <label>
                <span class="field-label">Latitude</span>
                <input
                  class="field-control"
                  type="text"
                  inputmode="decimal"
                  placeholder="-16.448694"
                  autocomplete="off"
                  data-availability-latitude
                />
              </label>
              <label>
                <span class="field-label">Longitude</span>
                <input
                  class="field-control"
                  type="text"
                  inputmode="decimal"
                  placeholder="-46.906306"
                  autocomplete="off"
                  data-availability-longitude
                />
              </label>
            </div>
          </div>
        </div>

        <p class="availability-preview__helper" data-availability-helper>
          Use sua localização ou preencha latitude e longitude para consultar a
          pré-análise.
        </p>

        <button
          class="availability-submit"
          type="button"
          data-availability-submit
          disabled
        >
          Consultar pré-análise
        </button>

        <div
          class="availability-result"
          data-availability-result
          aria-live="polite"
          hidden
        >
          <p class="availability-result__eyebrow">Resultado da pré-análise</p>
          <h3 data-availability-result-title>Pré-análise</h3>
          <p data-availability-result-message>
            A resposta aparecerá aqui depois da consulta.
          </p>
          <a
            class="availability-result__whatsapp"
            href={`https://wa.me/${site.whatsapp.digits}`}
            target="_blank"
            rel="noopener noreferrer"
            data-availability-whatsapp
          >
            Continuar pelo WhatsApp
          </a>
        </div>

        <p class="privacy-note">
          Sem cadastro. Não pedimos nome, telefone, e-mail ou CPF. A pré-análise
          usa apenas coordenadas para indicar um sinal inicial de viabilidade.
        </p>
      </div>

      <aside
        class="visual-card availability-preview__map"
        aria-label="Prévia visual sem Google Maps"
      >
        <div class="mock-map" aria-hidden="true">
          <span class="mock-map__line mock-map__line--one"></span>
          <span class="mock-map__line mock-map__line--two"></span>
          <span class="mock-map__pin"></span>
          <span class="mock-map__ring"></span>
        </div>
        <div class="availability-preview__map-copy">
          <p class="section-kicker">Mapa sob demanda</p>
          <h3>Ponto informado, sem infraestrutura exposta.</h3>
          <p>
            O Google Maps não carrega na abertura. Nesta onda, a pré-análise
            funciona por GPS do navegador, coordenadas ou atendimento pelo
            WhatsApp.
          </p>
          <a
            href={`https://wa.me/${site.whatsapp.digits}?text=${encodeURIComponent("Olá! Quero verificar a disponibilidade da Rural Conecta e posso informar minha localização pelo WhatsApp.")}`}
            target="_blank"
            rel="noopener noreferrer"
          >
            Enviar localização pelo WhatsApp
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  import "../../scripts/availability";
</script>

<style>
  .availability-preview__path {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
    margin: 0 0 1rem;
    padding: 0;
    list-style: none;
  }

  .availability-preview__path li {
    display: flex;
    min-height: 3.8rem;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    background: rgba(245, 247, 243, 0.035);
    color: var(--color-text-secondary);
    font-size: 0.86rem;
    font-weight: 760;
    line-height: 1.25;
    padding: 0.7rem;
  }

  .availability-preview__path span {
    display: grid;
    width: 1.75rem;
    height: 1.75rem;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 999px;
    background: var(--color-green-soft);
    color: var(--color-green-300);
    font-size: 0.78rem;
    font-weight: 950;
  }

  .availability-preview__grid {
    display: grid;
    gap: 1rem;
  }

  .availability-preview__panel {
    display: grid;
    gap: 0.9rem;
  }

  .availability-preview__panel-header {
    display: grid;
    gap: 0.45rem;
  }

  .availability-preview__panel-header h3 {
    font-size: clamp(1.35rem, 6vw, 2rem);
    line-height: 1.08;
  }

  .availability-preview__panel-header p:not(.section-kicker) {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .availability-preview__block {
    display: grid;
    gap: 0.75rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    background: rgba(2, 11, 12, 0.24);
    padding: 0.85rem;
  }

  .availability-preview__selected {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
    border: 1px solid var(--color-border-green);
    border-radius: var(--radius-control);
    background: var(--color-green-soft);
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    padding: 0.72rem;
  }

  .availability-preview__selected p {
    margin: 0;
  }

  .availability-preview__selected span {
    width: 0.72rem;
    height: 0.72rem;
    flex: 0 0 auto;
    margin-top: 0.42rem;
    border-radius: 999px;
    background: var(--color-green-300);
    box-shadow: 0 0 0 0.32rem rgba(161, 242, 124, 0.12);
  }

  .availability-preview__methods {
    display: grid;
    gap: 0.62rem;
  }

  .method-card {
    display: grid;
    width: 100%;
    min-height: 4.4rem;
    grid-template-columns: auto 1fr;
    gap: 0.72rem;
    align-items: center;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    background: rgba(2, 11, 12, 0.34);
    color: var(--color-text-primary);
    cursor: pointer;
    padding: 0.78rem;
    text-align: left;
    transition: var(--transition-interactive);
  }

  .method-card:hover,
  .method-card:focus-visible,
  .method-card--active {
    border-color: var(--color-border-green);
    background: rgba(99, 212, 59, 0.09);
  }

  .method-card--active {
    box-shadow: 0 0 0 1px rgba(99, 212, 59, 0.08);
  }

  .method-card__icon {
    display: grid;
    min-width: 2.9rem;
    min-height: 2.9rem;
    place-items: center;
    border: 1px solid var(--color-border-green);
    border-radius: 0.9rem;
    color: var(--color-green-300);
    font-size: 0.7rem;
    font-weight: 900;
    line-height: 1;
  }

  .method-card strong,
  .method-card small {
    display: block;
  }

  .method-card small {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.33;
    margin-top: 0.12rem;
  }

  .availability-preview__manual,
  .availability-preview__coordinates,
  .availability-preview__search-box,
  .availability-preview__coordinate-card {
    display: grid;
    gap: 0.75rem;
  }

  .availability-preview__coordinate-card {
    border: 1px solid rgba(216, 155, 95, 0.32);
    border-radius: var(--radius-card);
    background: rgba(216, 155, 95, 0.06);
    padding: 0.85rem;
  }

  .availability-preview__coordinate-copy {
    display: grid;
    gap: 0.25rem;
  }

  .availability-preview__coordinate-copy p:not(.section-kicker) {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .field-hint,
  .availability-preview__helper {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.45;
    margin: 0;
  }

  .availability-preview__helper {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-control);
    background: rgba(2, 11, 12, 0.3);
    padding: 0.82rem;
  }

  .availability-submit {
    min-height: var(--button-height-large);
    border: 1px solid var(--color-primary-hover);
    border-radius: 1.05rem;
    background: var(--gradient-primary);
    color: var(--color-text-inverse);
    cursor: pointer;
    font-weight: 900;
    padding: 0.95rem 1.2rem;
  }

  .availability-submit:disabled {
    border-color: var(--color-border-subtle);
    background: rgba(245, 247, 243, 0.08);
    color: var(--color-text-muted);
    cursor: not-allowed;
  }

  .availability-result {
    display: grid;
    gap: 0.65rem;
    border: 1px solid var(--color-border-green);
    border-radius: var(--radius-card);
    background: rgba(2, 11, 12, 0.42);
    padding: 1rem;
  }

  .availability-result[hidden] {
    display: none;
  }

  .availability-result__eyebrow {
    color: var(--color-green-300);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0;
    text-transform: uppercase;
  }

  .availability-result h3 {
    color: var(--color-text-primary);
    font-size: 1.25rem;
    line-height: 1.15;
    margin: 0;
  }

  .availability-result p:not(.availability-result__eyebrow) {
    color: var(--color-text-secondary);
    margin: 0;
  }

  .availability-result__whatsapp {
    display: inline-flex;
    min-height: var(--touch-target-min);
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-control);
    background: var(--gradient-primary);
    color: var(--color-text-inverse);
    font-weight: 900;
    padding: 0.8rem 1rem;
    text-align: center;
    text-decoration: none;
  }

  .availability-result[data-status="sem_viabilidade_automatica"],
  .availability-result[data-status="necessita_confirmacao"] {
    border-color: rgba(216, 155, 95, 0.5);
  }

  .availability-result[data-status="entrada_invalida"],
  .availability-result[data-status="limite_excedido"],
  .availability-result[data-status="erro_temporario"],
  .availability-result[data-status="falha_rede"] {
    border-color: rgba(241, 120, 107, 0.58);
  }

  .availability-preview__map {
    display: grid;
    min-height: 27rem;
    overflow: hidden;
    padding: 0;
  }

  .availability-preview__map-copy {
    display: grid;
    gap: 0.65rem;
    padding: 1.15rem;
  }

  .availability-preview__map-copy h3 {
    font-size: clamp(1.35rem, 7vw, 2.15rem);
    line-height: 1.08;
  }

  .availability-preview__map-copy p:not(.section-kicker) {
    color: var(--color-text-muted);
  }

  .availability-preview__map-copy a {
    color: var(--color-green-300);
    font-weight: 850;
    text-decoration: none;
  }

  @media (min-width: 42rem) {
    .availability-preview__path {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .availability-preview__coordinates {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 60rem) {
    .availability-preview__grid {
      grid-template-columns: minmax(0, 0.9fr) minmax(26rem, 1.1fr);
      align-items: stretch;
      gap: 1.25rem;
    }

    .availability-preview__map {
      min-height: auto;
    }
  }
</style>
