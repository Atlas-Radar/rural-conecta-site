---
import Button from "../components/ui/Button.astro";
import { createWhatsAppUrl, site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const whatsappHref = createWhatsAppUrl(
  "Olá! Quero verificar a disponibilidade da Rural Conecta para minha propriedade.",
);
---

<BaseLayout
  title={`${site.name} | Internet Rural`}
  description={site.description}
>
  <section class="hero">
    <div class="container hero__content">
      <p class="eyebrow">Conexão que move o campo</p>
      <h1>Internet de verdade para quem vive no campo.</h1>
      <p class="hero__lead">
        Fibra, rádio e soluções dedicadas para levar conexão estável até sua
        casa, fazenda, comunidade ou empresa na zona rural.
      </p>
      <div class="hero__actions" aria-label="Ações principais">
        <Button href="#disponibilidade">Verificar disponibilidade</Button>
        <Button
          href={whatsappHref}
          variant="secondary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Falar no WhatsApp
        </Button>
      </div>
      <p class="hero__meta">Atendimento local • Sem cadastro para consultar</p>
    </div>
  </section>

  <section
    id="disponibilidade"
    class="section availability"
    aria-labelledby="disponibilidade-title"
  >
    <div class="container availability__card">
      <div class="availability__intro">
        <p class="eyebrow">Consulta de viabilidade</p>
        <h2 id="disponibilidade-title">Verifique a disponibilidade.</h2>
        <p>
          A consulta completa será ativada quando o contrato da API estiver
          confirmado. Nesta base inicial, nenhum dado de localização é coletado
          e nenhuma integração externa é chamada.
        </p>
      </div>

      <div>
        <ul class="availability__list" aria-label="Próximas etapas da consulta">
          <li>Escolha da região com centro e zoom padrão.</li>
          <li>Localização por GPS, busca, mapa ou coordenadas.</li>
          <li>Resultado simples: atende ou não atende.</li>
        </ul>
        <p class="notice">
          Enquanto a verificação automática não entra, o atendimento segue pelo
          WhatsApp oficial da Rural Conecta.
        </p>
        <div class="availability__actions">
          <Button href={whatsappHref} target="_blank" rel="noopener noreferrer">
            Falar com atendimento
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section
    id="como-funciona"
    class="section steps"
    aria-labelledby="como-funciona-title"
  >
    <div class="container">
      <div class="steps__header">
        <p class="eyebrow">Como vai funcionar</p>
        <h2 id="como-funciona-title">Um fluxo simples para áreas rurais.</h2>
      </div>

      <ol class="steps__list">
        <li class="steps__item">
          <h3>Escolha sua região</h3>
          <p>
            A lista virá da API própria quando o contrato real for definido.
          </p>
        </li>
        <li class="steps__item">
          <h3>Informe o ponto</h3>
          <p>O mapa será carregado somente quando o visitante solicitar.</p>
        </li>
        <li class="steps__item">
          <h3>Continue pelo WhatsApp</h3>
          <p>A análise e contratação seguem com atendimento humano.</p>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>
