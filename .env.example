PUBLIC_SITE_URL=

# Google Maps JavaScript API: chave PUBLIC por definição, embutida no bundle
# quando usada no build. Segurança vem de restrição no Google Cloud por
# HTTP referrers + APIs permitidas, não de segredo no frontend.
# Consulte docs/MAPS_KEYS_VALIDATION.md antes de validar local/prod.
PUBLIC_GOOGLE_MAPS_API_KEY=
PUBLIC_GOOGLE_MAP_ID=

PUBLIC_WHATSAPP_NUMBER=

# Opcional para desenvolvimento local com Atlas rodando via npm start:
# PUBLIC_ATLAS_API_BASE_URL=http://localhost:3001

# Opcional para desenvolvimento local com Atlas via compose:
# PUBLIC_ATLAS_API_BASE_URL=http://localhost:3101

VIABILITY_API_BASE_URL=
VIABILITY_API_TOKEN=
