---
import Button from "../ui/Button.astro";
import { createWhatsAppUrl } from "../../data/site";

const whatsappHref = createWhatsAppUrl(
  "Olá! Quero verificar a disponibilidade da Rural Conecta para minha propriedade.",
);

const benefits = [
  "Sem cadastro para consultar",
  "Atendimento local",
  "Mapa só quando precisar",
] as const;
---

<section class="site-hero" aria-labelledby="hero-title">
  <picture class="site-hero__media" aria-hidden="true">
    <source
      media="(max-width: 47.99rem)"
      srcset="/images/hero/hero-tecnico-mobile.avif"
      type="image/avif"
    />
    <source
      media="(max-width: 47.99rem)"
      srcset="/images/hero/hero-tecnico-mobile.webp"
      type="image/webp"
    />
    <source srcset="/images/hero/hero-tecnico-desktop.avif" type="image/avif" />
    <source srcset="/images/hero/hero-tecnico-desktop.webp" type="image/webp" />
    <img
      src="/images/hero/hero-tecnico-desktop.webp"
      alt=""
      width="1280"
      height="720"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </picture>

  <div class="container site-hero__inner">
    <div class="site-hero__content">
      <p class="site-hero__eyebrow">
        <svg
          aria-hidden="true"
          focusable="false"
          viewBox="0 0 24 24"
          width="18"
          height="18"
        >
          <path d="M5 12.6a9.8 9.8 0 0 1 14 0"></path>
          <path d="M8.4 15.9a5.1 5.1 0 0 1 7.2 0"></path>
          <path d="M12 19h.01"></path>
        </svg>
        <span>Conexão que move o campo</span>
      </p>

      <h1 id="hero-title">
        Internet de verdade para quem vive no campo<span>.</span>
      </h1>

      <div class="site-hero__text">
        <p class="site-hero__lead">
          Atendimento local para comunidades, fazendas e empresas rurais.
        </p>
        <p class="site-hero__support">
          Consulte sua localização sem cadastro e continue pelo WhatsApp com uma
          pessoa da equipe.
        </p>
      </div>

      <div class="site-hero__actions" aria-label="Ações principais">
        <Button href="#disponibilidade" data-availability-modal-open>
          <svg
            class="site-hero__button-icon"
            aria-hidden="true"
            focusable="false"
            viewBox="0 0 24 24"
            width="20"
            height="20"
          >
            <path
              d="M12 21.2s6.7-6.1 6.7-11.3a6.7 6.7 0 1 0-13.4 0c0 5.2 6.7 11.3 6.7 11.3Z"
            ></path>
            <circle cx="12" cy="9.9" r="2.35"></circle>
          </svg>
          <span>Verificar disponibilidade</span>
        </Button>

        <Button
          href={whatsappHref}
          variant="secondary"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            class="site-hero__button-icon"
            aria-hidden="true"
            focusable="false"
            viewBox="0 0 24 24"
            width="20"
            height="20"
          >
            <path d="M6.4 19.2 7.2 16A7.5 7.5 0 1 1 10 18.1l-3.6 1.1Z"></path>
            <path
              d="M9.3 8.6c.2-.4.4-.4.7-.4h.5c.2 0 .4.1.5.4l.7 1.5c.1.3.1.5-.1.7l-.4.5c.6 1 1.4 1.8 2.5 2.4l.5-.5c.2-.2.5-.2.7-.1l1.5.7c.3.1.4.3.4.6v.5c0 .3-.1.5-.4.7-.4.3-.9.4-1.5.3-3-.3-5.7-2.9-6-6 0-.6.1-1.1.4-1.5Z"
            ></path>
          </svg>
          <span>Falar no WhatsApp</span>
        </Button>
      </div>
    </div>

    <ul class="site-hero__benefits" aria-label="Benefícios da consulta">
      {
        benefits.map((benefit) => (
          <li>
            <svg
              aria-hidden="true"
              focusable="false"
              viewBox="0 0 24 24"
              width="18"
              height="18"
            >
              <path d="m5 12 4 4L19 6" />
            </svg>
            <span>{benefit}</span>
          </li>
        ))
      }
    </ul>

    <div class="site-hero__visual-frame" aria-hidden="true"></div>
  </div>
</section>

<style>
  .site-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: calc(100svh - 5rem);
    overflow: hidden;
    padding-block: 2rem 2.25rem;
  }

  .site-hero::before {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        180deg,
        rgba(2, 11, 12, 0.68) 0%,
        rgba(2, 11, 12, 0.5) 34%,
        rgba(2, 11, 12, 0.94) 100%
      ),
      linear-gradient(
        90deg,
        rgba(2, 11, 12, 0.98) 0%,
        rgba(2, 11, 12, 0.82) 56%,
        rgba(2, 11, 12, 0.5) 100%
      );
    content: "";
  }

  .site-hero::after {
    position: absolute;
    inset: auto 0 0;
    z-index: 1;
    height: 34%;
    background: linear-gradient(
      180deg,
      transparent,
      rgba(99, 212, 59, 0.08) 42%,
      rgba(2, 11, 12, 0.92)
    );
    content: "";
    pointer-events: none;
  }

  .site-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .site-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .site-hero__inner {
    position: relative;
    z-index: 2;
    display: grid;
    align-content: center;
    gap: 1.4rem;
  }

  .site-hero__content {
    display: grid;
    max-width: 38rem;
    gap: 1.15rem;
  }

  .site-hero__eyebrow {
    display: inline-flex;
    width: fit-content;
    max-width: 100%;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.65rem;
    border: 1px solid rgba(99, 212, 59, 0.42);
    border-radius: var(--radius-chip);
    background: rgba(2, 11, 12, 0.54);
    color: var(--color-green-300);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1.1;
    padding: 0.7rem 0.95rem;
    text-transform: uppercase;
    box-shadow: 0 0.7rem 1.7rem rgba(0, 0, 0, 0.22);
  }

  .site-hero__eyebrow svg,
  .site-hero__button-icon,
  .site-hero__benefits svg {
    flex: 0 0 auto;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.2;
  }

  .site-hero h1 {
    max-width: 10ch;
    font-size: 3.25rem;
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.98;
    text-wrap: balance;
  }

  .site-hero h1 span {
    color: var(--color-green-300);
  }

  .site-hero__text {
    display: grid;
    gap: 0.45rem;
    max-width: 34rem;
  }

  .site-hero__lead {
    color: var(--color-text-secondary);
    font-size: 1.12rem;
    font-weight: 650;
    line-height: 1.45;
  }

  .site-hero__support {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.55;
  }

  .site-hero__actions {
    display: grid;
    gap: 0.8rem;
    margin-top: 0.15rem;
  }

  .site-hero__actions :global(.button) {
    width: 100%;
    min-height: var(--button-height-large);
    gap: 0.7rem;
    border-radius: 1.15rem;
    padding: 1rem 1.15rem;
  }

  .site-hero__actions :global(.button--primary) {
    border-color: var(--color-primary-hover);
    background: var(--gradient-primary);
    box-shadow: 0 1rem 2.2rem rgba(99, 212, 59, 0.18);
  }

  .site-hero__actions :global(.button--secondary) {
    border-color: rgba(161, 242, 124, 0.32);
    background: rgba(2, 11, 12, 0.48);
  }

  .site-hero__benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    max-width: 36rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-hero__benefits li {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(245, 247, 243, 0.13);
    border-radius: var(--radius-chip);
    background: rgba(5, 19, 18, 0.72);
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    font-weight: 750;
    line-height: 1.15;
    padding: 0.62rem 0.78rem;
  }

  .site-hero__benefits svg {
    color: var(--color-green-300);
    stroke-width: 2.4;
  }

  .site-hero__visual-frame {
    display: none;
  }

  @media (max-width: 22.99rem) {
    .site-hero h1 {
      font-size: 3.05rem;
    }

    .site-hero__eyebrow {
      font-size: 0.72rem;
      padding-inline: 0.85rem;
    }
  }

  @media (min-width: 30rem) {
    .site-hero__actions {
      grid-template-columns: minmax(0, auto) minmax(0, auto);
      justify-content: start;
    }

    .site-hero__actions :global(.button) {
      width: auto;
      min-width: 13rem;
    }
  }

  @media (min-width: 48rem) {
    .site-hero {
      min-height: calc(100svh - 5.5rem);
      padding-block: 4.5rem;
    }

    .site-hero::before {
      background: linear-gradient(
        90deg,
        rgba(2, 11, 12, 0.99) 0%,
        rgba(2, 11, 12, 0.92) 42%,
        rgba(2, 11, 12, 0.2) 62%,
        rgba(2, 11, 12, 0.02) 100%
      );
    }

    .site-hero__inner {
      grid-template-columns: minmax(0, 0.92fr) minmax(22rem, 0.78fr);
      align-items: center;
      gap: 2rem;
      min-height: calc(100svh - 14.5rem);
    }

    .site-hero__content,
    .site-hero__benefits {
      grid-column: 1;
    }

    .site-hero h1 {
      max-width: 11ch;
      font-size: 4.6rem;
    }

    .site-hero__lead {
      font-size: 1.2rem;
    }

    .site-hero__visual-frame {
      display: block;
      grid-row: 1 / span 2;
      grid-column: 2;
      align-self: stretch;
      min-height: 32rem;
      border: 1px solid rgba(161, 242, 124, 0.22);
      border-radius: 1.8rem;
      background:
        linear-gradient(90deg, rgba(2, 11, 12, 0.1), rgba(2, 11, 12, 0.18)),
        url("/images/hero/hero-tecnico-desktop.webp");
      background-position: center;
      background-size: cover;
      box-shadow:
        inset 0 0 0 1px rgba(245, 247, 243, 0.04),
        0 1.5rem 3rem rgba(0, 0, 0, 0.24),
        0 0 2rem rgba(99, 212, 59, 0.08);
      pointer-events: none;
    }

    @supports (
      background-image: image-set(
          url("/images/hero/hero-tecnico-desktop.avif") type("image/avif")
        )
    ) {
      .site-hero__visual-frame {
        background-image:
          linear-gradient(90deg, rgba(2, 11, 12, 0.1), rgba(2, 11, 12, 0.18)),
          image-set(
            url("/images/hero/hero-tecnico-desktop.avif") type("image/avif"),
            url("/images/hero/hero-tecnico-desktop.webp") type("image/webp")
          );
      }
    }
  }

  @media (min-width: 64rem) {
    .site-hero__inner {
      grid-template-columns: minmax(0, 0.9fr) minmax(26rem, 0.82fr);
      gap: 3rem;
    }

    .site-hero h1 {
      font-size: 5.15rem;
    }

    .site-hero__support {
      font-size: 1.06rem;
    }

    .site-hero__benefits li {
      border-radius: var(--radius-card);
      padding-inline: 0.9rem;
    }
  }
</style>
