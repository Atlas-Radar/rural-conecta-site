---
import { everydayBenefits } from "../../data/site";
---

<section
  id="beneficios"
  class="section-band section-band--dark benefits"
  aria-labelledby="beneficios-title"
>
  <div class="container benefits__grid">
    <div class="section-heading benefits__intro">
      <p class="section-kicker">Uso cotidiano</p>
      <h2 id="beneficios-title" class="section-title">
        Internet para a rotina real de quem vive no campo.
      </h2>
      <p class="section-lede">
        Sem logos de streaming ou promessas de parceiros. A seção mostra usos
        comuns que serão refinados com conteúdo real depois.
      </p>
    </div>

    <ul class="benefits__list" aria-label="Benefícios secundários">
      {
        everydayBenefits.map((benefit, index) => (
          <li class="benefits__item">
            <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
            {benefit}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .benefits__grid {
    display: grid;
    gap: 1.25rem;
  }

  .benefits__intro {
    margin-bottom: 0;
  }

  .benefits__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .benefits__item {
    display: grid;
    min-height: 7.5rem;
    align-content: space-between;
    gap: 0.8rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    background: rgba(245, 247, 243, 0.035);
    color: var(--color-text-secondary);
    font-weight: 820;
    padding: 0.9rem;
  }

  .benefits__item span {
    color: var(--color-green-300);
    font-size: 0.75rem;
    font-weight: 950;
  }

  @media (min-width: 48rem) {
    .benefits__grid {
      grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
      align-items: start;
    }

    .benefits__list {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
