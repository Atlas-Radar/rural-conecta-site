---
import { faqItems } from "../../data/site";
---

<section
  id="faq"
  class="section-band section-band--deep faq-section"
  aria-labelledby="faq-title"
>
  <div class="container faq-section__grid">
    <div class="section-heading faq-section__intro">
      <p class="section-kicker">FAQ</p>
      <h2 id="faq-title" class="section-title">
        Dúvidas comuns antes de chamar a equipe.
      </h2>
      <p class="section-lede">
        Respostas diretas sobre privacidade, localização, avaliação manual e
        próximos passos pelo WhatsApp.
      </p>
    </div>

    <div class="faq-section__items">
      {
        faqItems.map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-section__grid {
    display: grid;
    gap: 1.25rem;
  }

  .faq-section__intro {
    margin-bottom: 0;
  }

  .faq-section__items {
    display: grid;
    gap: 0.75rem;
  }

  .faq-item {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    background: rgba(245, 247, 243, 0.035);
    overflow: hidden;
  }

  .faq-item summary {
    min-height: var(--touch-target-min);
    cursor: pointer;
    color: var(--color-text-primary);
    font-weight: 860;
    padding: 1rem;
  }

  .faq-item p {
    border-top: 1px solid var(--color-border-subtle);
    color: var(--color-text-muted);
    padding: 0 1rem 1rem;
  }

  @media (min-width: 58rem) {
    .faq-section__grid {
      grid-template-columns: minmax(0, 0.78fr) minmax(30rem, 1.22fr);
      align-items: start;
    }
  }
</style>
