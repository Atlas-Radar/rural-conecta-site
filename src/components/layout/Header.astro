---
import { createWhatsAppUrl } from "../../data/site";

const whatsappHref = createWhatsAppUrl();

const navLinks = [
  { label: "Início", href: "/", isCurrent: true },
  { label: "Disponibilidade", href: "#disponibilidade" },
  { label: "Como funciona", href: "#como-funciona" },
  {
    label: "Atendimento",
    href: whatsappHref,
    target: "_blank",
    rel: "noopener noreferrer",
  },
];

const mobileLinks = [
  { label: "Início", href: "/" },
  { label: "Disponibilidade", href: "#disponibilidade" },
  { label: "Como funciona", href: "#como-funciona" },
  {
    label: "WhatsApp",
    href: whatsappHref,
    target: "_blank",
    rel: "noopener noreferrer",
  },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="Rural Conecta - página inicial">
      <picture class="brand__picture" aria-hidden="true">
        <source srcset="/brand/rural-conecta-mark.webp" type="image/webp" />
        <img
          class="brand__logo"
          src="/brand/rural-conecta-mark.png"
          alt=""
          width="192"
          height="192"
          decoding="async"
        />
      </picture>
      <span class="brand__text" aria-hidden="true">
        <span class="brand__name">Rural</span>
        <span class="brand__descriptor">Conecta</span>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Principal">
      {
        navLinks.map((link) => (
          <a
            class:list={[
              "site-header__nav-link",
              link.isCurrent && "site-header__nav-link--current",
            ]}
            href={link.href}
            target={link.target}
            rel={link.rel}
            aria-current={link.isCurrent ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="site-header__actions" aria-label="Ações do cabeçalho">
      <a class="header-button header-button--secondary" href="#disponibilidade">
        <svg
          class="header-button__icon"
          aria-hidden="true"
          focusable="false"
          viewBox="0 0 24 24"
          width="18"
          height="18"
        >
          <path
            d="M12 21.2s6.7-6.1 6.7-11.3a6.7 6.7 0 1 0-13.4 0c0 5.2 6.7 11.3 6.7 11.3Z"
          ></path>
          <circle cx="12" cy="9.9" r="2.35"></circle>
        </svg>
        <span>Verificar disponibilidade</span>
      </a>
      <a
        class="header-button header-button--primary"
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          class="header-button__icon header-button__icon--whatsapp"
          aria-hidden="true"
          focusable="false"
          viewBox="0 0 24 24"
          width="18"
          height="18"
        >
          <path d="M6.4 19.2 7.2 16A7.5 7.5 0 1 1 10 18.1l-3.6 1.1Z"></path>
          <path
            d="M9.3 8.6c.2-.4.4-.4.7-.4h.5c.2 0 .4.1.5.4l.7 1.5c.1.3.1.5-.1.7l-.4.5c.6 1 1.4 1.8 2.5 2.4l.5-.5c.2-.2.5-.2.7-.1l1.5.7c.3.1.4.3.4.6v.5c0 .3-.1.5-.4.7-.4.3-.9.4-1.5.3-3-.3-5.7-2.9-6-6 0-.6.1-1.1.4-1.5Z"
          ></path>
        </svg>
        <span>WhatsApp</span>
        <svg
          class="header-button__icon header-button__icon--arrow"
          aria-hidden="true"
          focusable="false"
          viewBox="0 0 24 24"
          width="18"
          height="18"
        >
          <path d="M5 12h14"></path>
          <path d="m13 6 6 6-6 6"></path>
        </svg>
      </a>
    </div>

    <details class="mobile-menu">
      <summary class="mobile-menu__toggle">
        <span class="sr-only">Abrir menu de navegação</span>
        <svg
          class="mobile-menu__icon"
          aria-hidden="true"
          focusable="false"
          viewBox="0 0 32 32"
          width="32"
          height="32"
        >
          <path d="M7 10h18"></path>
          <path d="M7 16h18"></path>
          <path d="M7 22h18"></path>
        </svg>
      </summary>
      <nav class="mobile-menu__panel" aria-label="Principal">
        {
          mobileLinks.map((link) => (
            <a
              class="mobile-menu__link"
              href={link.href}
              target={link.target}
              rel={link.rel}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: relative;
    z-index: 10;
    border-bottom: 1px solid var(--color-border-subtle);
    background:
      radial-gradient(
        circle at 14% 0,
        rgba(99, 212, 59, 0.1),
        transparent 13rem
      ),
      linear-gradient(180deg, rgba(2, 11, 12, 0.98), rgba(3, 16, 15, 0.88));
    box-shadow: inset 0 -1px 0 rgba(99, 212, 59, 0.05);
  }

  .site-header__inner {
    display: flex;
    min-height: 5rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target-min);
    gap: 0.7rem;
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .brand__picture {
    display: block;
    width: 3.25rem;
    height: 3.25rem;
    flex: 0 0 auto;
  }

  .brand__logo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .brand__text {
    display: grid;
    gap: 0.05rem;
    line-height: 1;
    white-space: nowrap;
  }

  .brand__name {
    color: var(--color-text-primary);
    font-size: clamp(1.45rem, 6vw, 1.7rem);
    font-weight: 900;
    letter-spacing: 0;
  }

  .brand__descriptor {
    color: var(--color-green-300);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  .site-header__nav {
    display: none;
  }

  .site-header__actions {
    display: none;
  }

  .header-button {
    display: inline-flex;
    min-height: var(--touch-target-min);
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: var(--radius-control);
    font-weight: 800;
    line-height: 1;
    padding: 0.85rem 1.05rem;
    text-decoration: none;
    transition: var(--transition-interactive);
  }

  .header-button__icon {
    flex: 0 0 auto;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.1;
  }

  .header-button__icon--whatsapp {
    stroke-width: 1.9;
  }

  .header-button__icon--arrow {
    margin-inline-start: -0.1rem;
  }

  .header-button--secondary {
    border: 1px solid var(--color-border-subtle);
    background: rgba(245, 247, 243, 0.03);
    color: var(--color-text-primary);
  }

  .header-button--secondary:hover {
    border-color: var(--color-border-green);
    color: var(--color-green-300);
  }

  .header-button--primary {
    border: 1px solid var(--color-primary);
    background: var(--gradient-primary);
    color: var(--color-text-inverse);
    box-shadow: 0 0.8rem 1.8rem rgba(99, 212, 59, 0.14);
  }

  .header-button--primary:hover {
    border-color: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .mobile-menu {
    position: relative;
    display: block;
    flex: 0 0 auto;
  }

  .mobile-menu__toggle {
    display: grid;
    width: 4rem;
    min-height: 4rem;
    place-items: center;
    gap: 0.28rem;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-card);
    background: rgba(245, 247, 243, 0.04);
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
    transition: var(--transition-interactive);
  }

  .mobile-menu__toggle::-webkit-details-marker {
    display: none;
  }

  .mobile-menu__toggle:hover {
    border-color: var(--color-border-green);
  }

  .mobile-menu__icon {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-width: 2.6;
  }

  .mobile-menu__panel {
    position: absolute;
    top: calc(100% + 0.8rem);
    right: 0;
    display: grid;
    width: min(17rem, calc(100vw - 2rem));
    gap: 0.35rem;
    border: 1px solid var(--color-border-green);
    border-radius: var(--radius-card);
    background: rgba(3, 16, 15, 0.98);
    box-shadow: var(--shadow-elevated);
    padding: 0.55rem;
  }

  .mobile-menu__link {
    display: flex;
    min-height: var(--touch-target-min);
    align-items: center;
    border-radius: var(--radius-control);
    color: var(--color-text-secondary);
    font-weight: 700;
    padding: 0.75rem 0.95rem;
    text-decoration: none;
  }

  .mobile-menu__link:hover,
  .mobile-menu__link:focus-visible {
    background: var(--color-green-soft);
    color: var(--color-text-primary);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (max-width: 63.99rem) {
    .site-header:has(.mobile-menu[open]) {
      margin-bottom: 15.25rem;
    }
  }

  @media (min-width: 64rem) {
    .site-header__inner {
      display: grid;
      min-height: 5.5rem;
      grid-template-columns: auto minmax(22rem, 1fr) auto;
      gap: 1.25rem;
    }

    .site-header__nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      color: var(--color-text-muted);
      font-size: 0.95rem;
    }

    .site-header__nav-link {
      position: relative;
      display: inline-flex;
      min-height: var(--touch-target-min);
      align-items: center;
      border-radius: var(--radius-button);
      padding: 0.75rem 0.9rem;
      text-decoration: none;
      transition: var(--transition-interactive);
    }

    .site-header__nav-link::after {
      position: absolute;
      right: 0.9rem;
      bottom: 0.45rem;
      left: 0.9rem;
      height: 2px;
      border-radius: 999px;
      background: transparent;
      content: "";
    }

    .site-header__nav-link:hover {
      background: rgba(245, 247, 243, 0.03);
      color: var(--color-text-primary);
    }

    .site-header__nav-link--current {
      color: var(--color-green-300);
      font-weight: 800;
    }

    .site-header__nav-link--current::after {
      background: var(--color-green-300);
    }

    .site-header__actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.75rem;
    }

    .mobile-menu {
      display: none;
    }
  }

  @media (min-width: 72rem) {
    .site-header__inner {
      gap: 1.5rem;
    }

    .header-button {
      padding-inline: 1.15rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .header-button,
    .mobile-menu__toggle,
    .site-header__nav-link {
      transition: none;
    }

    .header-button--primary:hover {
      transform: none;
    }
  }
</style>
