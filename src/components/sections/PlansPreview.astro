---
import Button from "../ui/Button.astro";
import { planPreviews } from "../../data/site";
---

<section
  id="planos"
  class="section-band section-band--light plans-preview"
  aria-labelledby="planos-title"
>
  <div class="container">
    <div
      class="section-heading section-heading--centered section-heading--inverted"
    >
      <p class="section-kicker">Planos sob consulta</p>
      <h2 id="planos-title" class="section-title">
        Categorias para cada rotina no campo.
      </h2>
      <p class="section-lede">
        Sem preço ou velocidade inventados. A melhor recomendação depende da
        pré-análise do ponto e da avaliação manual da equipe.
      </p>
    </div>

    <p class="plans-preview__note">
      Use os cards como guia inicial: casa rural, sítio/fazenda ou empresa
      produtiva. A condição comercial é confirmada no atendimento.
    </p>

    <div
      class="plans-preview__cards"
      aria-label="Categorias de planos sob consulta"
    >
      {
        planPreviews.map((plan) => (
          <article class="plan-card">
            <div class="plan-card__header">
              <p class="plan-card__tag">Sob consulta</p>
              <h3>{plan.name}</h3>
              <p class="plan-card__audience">{plan.audience}</p>
            </div>
            <dl class="plan-card__facts">
              <div>
                <dt>Velocidade</dt>
                <dd>{plan.speed}</dd>
              </div>
              <div>
                <dt>Valor</dt>
                <dd>{plan.price}</dd>
              </div>
            </dl>
            <ul>
              {plan.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
            <Button href="#disponibilidade" variant="secondary">
              Fazer pré-análise
            </Button>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .plans-preview__note {
    max-width: 42rem;
    margin: -0.35rem auto 1rem;
    color: rgba(4, 17, 13, 0.7);
    font-weight: 720;
    text-align: center;
  }

  .plans-preview__cards {
    display: flex;
    gap: 0.9rem;
    margin-inline: calc(var(--container-padding) * -1);
    overflow-x: auto;
    padding: 0 var(--container-padding) 0.35rem;
    scroll-snap-type: x mandatory;
  }

  .plan-card {
    display: grid;
    min-width: min(20.5rem, 86vw);
    gap: 0.95rem;
    border: 1px solid rgba(4, 17, 13, 0.14);
    border-radius: var(--radius-card-lg);
    background: #ffffff;
    color: var(--color-text-inverse);
    padding: clamp(1.15rem, 4vw, 1.55rem);
    scroll-snap-align: start;
    box-shadow: 0 1rem 2.2rem rgba(4, 17, 13, 0.08);
  }

  .plan-card__header {
    display: grid;
    gap: 0.5rem;
  }

  .plan-card__tag {
    width: fit-content;
    border-radius: var(--radius-chip);
    background: rgba(99, 212, 59, 0.16);
    color: #245719;
    font-size: 0.76rem;
    font-weight: 950;
    padding: 0.3rem 0.7rem;
    text-transform: uppercase;
  }

  .plan-card h3 {
    font-size: clamp(1.45rem, 6vw, 1.85rem);
    line-height: 1.08;
  }

  .plan-card__audience {
    color: rgba(4, 17, 13, 0.68);
    font-weight: 760;
  }

  .plan-card__facts {
    display: grid;
    gap: 0.65rem;
    margin: 0;
  }

  .plan-card__facts div {
    border: 1px solid rgba(4, 17, 13, 0.12);
    border-radius: var(--radius-card);
    background: #f5f8f1;
    padding: 0.75rem;
  }

  .plan-card dt {
    color: rgba(4, 17, 13, 0.58);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .plan-card dd {
    margin: 0;
    font-weight: 950;
  }

  .plan-card ul {
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding-left: 1.1rem;
    color: rgba(4, 17, 13, 0.74);
  }

  .plan-card :global(.button--secondary) {
    border-color: rgba(4, 17, 13, 0.18);
    background: var(--color-background-main);
    color: var(--color-text-primary);
  }

  @media (min-width: 58rem) {
    .plans-preview__cards {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-inline: 0;
      overflow: visible;
      padding: 0;
    }

    .plan-card {
      min-width: 0;
    }
  }
</style>
